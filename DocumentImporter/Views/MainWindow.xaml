<Window x:Class="DocumentImporter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DocumentImporter.ViewModels"
        Title="Document Importer" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek + przycisk importu -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
               Text="Document Importer"
               FontSize="24" FontWeight="Bold"
               VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">

                <Button Content="Import CSV oraz zapis do bazy danych"
                Command="{Binding ImportCommand}"
                Padding="16,8" FontSize="14"
                Background="#2563EB" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                Margin="0,0,8,0"/>

                <Button Content="Załaduj z bazy"
                Command="{Binding LoadFromDatabaseCommand}"
                Padding="16,8" FontSize="14"
                Background="#16A34A" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                Margin="0,0,8,0"/>

                <Button Content="Wyczyść"
                Command="{Binding ClearCommand}"
                Padding="16,8" FontSize="14"
                Background="#DC2626" Foreground="White"
                BorderThickness="0" Cursor="Hand"/>
                
            </StackPanel>
        </Grid>

        <!-- Filtry -->
        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="6"
                Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Szukaj:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Padding="6,4" Margin="0,0,16,0"/>

                <TextBlock Text="Typ:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding DocumentTypes}"
                          SelectedItem="{Binding FilterType}"
                          Width="130" Padding="6,4"/>
            </StackPanel>
        </Border>

        <!-- Tabela dokumentów -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Documents}"
                  SelectedItem="{Binding SelectedDocument}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Margin="0,0,0,12">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                    Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Typ"
                    Binding="{Binding Type}" Width="100"/>
                <DataGridTextColumn Header="Data"
                    Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Imię"
                    Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Nazwisko"
                    Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Miasto"
                    Binding="{Binding City}" Width="*"/>
                <DataGridTextColumn Header="Pozycji"
                    Binding="{Binding Items.Count}" Width="70"/>
            </DataGrid.Columns>

            <!-- Podwójne kliknięcie otwiera szczegóły -->
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding ShowDetailCommand}"/>
            </DataGrid.InputBindings>
        </DataGrid>

        <!-- Pasek statusu -->
        <Border Grid.Row="3" Background="#F0F9FF" CornerRadius="4" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center">
                    <Run Text="Wyświetlono: "/>
                    <Run Text="{Binding Documents.Count, Mode=OneWay}"/>
                    <Run Text=" dokumentów"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>